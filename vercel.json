{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "vite"
    },
    "backend": {
      "root": "backend"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": {
        "type": "service",
        "service": "backend",
        "path": "/api/:path*"
      }
    },
    {
      "source": "/uploads/:path*",
      "destination": {
        "type": "service",
        "service": "backend",
        "path": "/uploads/:path*"
      }
    },
    {
      "source": "/:path*",
      "destination": {
        "type": "service",
        "service": "frontend",
        "path": "/:path*"
      }
    }
  ]
}
